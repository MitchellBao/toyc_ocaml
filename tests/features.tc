int g = 3;
const int c = 4;

int add(int a, int b) {
    return a + b;
}

int main() {
    int i = 0;
    int sum = 0;
    while (i < 10) {
        i = i + 1;
        if (i == 5) {
            continue;
        }
        if (i == 8) {
            break;
        }
        sum = sum + add(i, g) + c;
    }
    return sum;
}
